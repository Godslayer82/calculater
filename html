<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Calculator</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
    }

    body {
      background: linear-gradient(135deg, #1e1e1e, #2b2b2b);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      color: white;
    }

    .calculator {
      background: #111;
      padding: 20px;
      border-radius: 20px;
      width: 320px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .display {
      width: 100%;
      height: 70px;
      background: #222;
      border: none;
      border-radius: 12px;
      margin-bottom: 15px;
      text-align: right;
      font-size: 2rem;
      padding: 15px;
      color: white;
    }

    .buttons {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }

    button {
      height: 60px;
      border: none;
      border-radius: 12px;
      font-size: 1.3rem;
      cursor: pointer;
      background: #333;
      color: white;
      transition: 0.2s;
    }

    button:hover {
      background: #444;
      transform: scale(1.03);
    }

    .operator {
      background: #ff9500;
    }

    .operator:hover {
      background: #ffaa33;
    }

    .secret-screen {
      display: none;
      position: fixed;
      inset: 0;
      background: #0d1117;
      color: #00ff88;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      text-align: center;
      padding: 20px;
      z-index: 999;
    }

    .secret-screen h1 {
      font-size: 3rem;
      margin-bottom: 20px;
    }

    .secret-screen p {
      font-size: 1.2rem;
      max-width: 600px;
      line-height: 1.5;
    }

    .close-btn {
      margin-top: 30px;
      padding: 12px 24px;
      background: #00ff88;
      color: black;
      font-weight: bold;
    }
  </style>
</head>
<body>

  <div class="calculator">
    <input type="text" class="display" id="display" readonly>

    <div class="buttons">
      <button onclick="append('7')">7</button>
      <button onclick="append('8')">8</button>
      <button onclick="append('9')">9</button>
      <button class="operator" onclick="append('/')">÷</button>

      <button onclick="append('4')">4</button>
      <button onclick="append('5')">5</button>
      <button onclick="append('6')">6</button>
      <button class="operator" onclick="append('*')">×</button>

      <button onclick="append('1')">1</button>
      <button onclick="append('2')">2</button>
      <button onclick="append('3')">3</button>
      <button class="operator" onclick="append('-')">−</button>

      <button onclick="append('0')">0</button>
      <button onclick="append('.')">.</button>
      <button onclick="calculate()">=</button>
      <button class="operator" onclick="append('+')">+</button>

      <button onclick="clearDisplay()" style="grid-column: span 4; background:#ff3b30;">
        Clear
      </button>
    </div>
  </div>

  <div class="secret-screen" id="secretScreen">
    <h1>⚠ SYSTEM BREACH DETECTED ⚠</h1>

    <p id="virusText">
      Your files are being encrypted...<br>
      Contacting remote server...<br>
      Downloading malware...<br><br>
      <strong>DO NOT TURN OFF YOUR DEVICE</strong>
    </p>

    <div style="width: 80%; height: 25px; background:#222; border-radius:10px; margin-top:25px; overflow:hidden;">
      <div id="progressBar" style="height:100%; width:0%; background:#00ff88;"></div>
    </div>

    <h2 id="percent" style="margin-top:15px;">0%</h2>

    <div id="terminal" style="margin-top:25px; width:90%; max-width:700px; height:180px; background:black; color:#00ff88; font-family:monospace; padding:15px; overflow:hidden; border:2px solid #00ff88; border-radius:10px; text-align:left; font-size:0.9rem;"></div>

    <button class="close-btn" onclick="closeSecret()">
      Escape
    </button>
  </div>

  <script>
    const display = document.getElementById('display');

    function append(value) {
      display.value += value;

      // Secret code detection
      if (display.value === '80085') {
        openSecret();
      }
    }

    function clearDisplay() {
      display.value = '';
    }

    function calculate() {
      try {
        display.value = eval(display.value);
      } catch {
        display.value = 'Error';
      }
    }

    function openSecret() {
      const secret = document.getElementById('secretScreen');
      const bar = document.getElementById('progressBar');
      const percent = document.getElementById('percent');
      const text = document.getElementById('virusText');

      secret.style.display = 'flex';
      display.value = '';

      let progress = 0;

      const messages = [
        'Injecting trojan.exe into kernel...',
        'Bypassing firewall security...',
        'Decrypting browser passwords...',
        'Uploading files to dark-web node...',
        'Remote access granted...',
        'Activating webcam surveillance...',
        'Extracting Discord tokens...',
        'Downloading classified data...',
        'Injecting ransomware payload...',
        'Tracking IP address...',
        'Accessing administrator controls...',
        'Deleting system32...',
        'Connecting to anonymous relay...',
        'Overclocking CPU for brute force...',
        'Mining cryptocurrency in background...',
        'Injecting spyware modules...',
        'Compromising network security...',
        'Synchronizing stolen data...',
        'ERROR: Antivirus disabled',
        'WARNING: BIOS corruption detected'
      ];

      const terminal = document.getElementById('terminal');

      const hackerLogs = [
        '[ROOT ACCESS GRANTED]',
        '[FIREWALL BREACHED]',
        '[REMOTE SERVER CONNECTED]',
        '[DATABASE EXPORTED]',
        '[ENCRYPTION KEYS STOLEN]',
        '[ADMIN OVERRIDE SUCCESSFUL]',
        '[SECURITY FAILURE DETECTED]',
        '[USER TRACKED SUCCESSFULLY]',
        '[KERNEL MODIFIED]',
        '[DARKNET NODE ACTIVE]',
        '[PAYLOAD DEPLOYED]',
        '[SYSTEM COMPROMISED]'
      ];

      const interval = setInterval(() => {
        progress += Math.floor(Math.random() * 10) + 3;

        if (progress > 100) progress = 100;

        bar.style.width = progress + '%';
        percent.textContent = progress + '%';

        text.innerHTML = messages[Math.floor(Math.random() * messages.length)] + '<br><br><strong>CRITICAL ERROR</strong>';

        const log = document.createElement('div');
        log.textContent = '> ' + hackerLogs[Math.floor(Math.random() * hackerLogs.length)];
        terminal.prepend(log);

        if (terminal.children.length > 12) {
          terminal.removeChild(terminal.lastChild);
        }

        if (progress >= 100) {
          clearInterval(interval);

          setTimeout(() => {
            secret.innerHTML = `
              <h1 style="color:#00ff88;">😂 YOU GOT TROLLED 😂</h1>
              <p>
                This was just a fake virus prank screen.<br><br>
                Nothing was actually downloaded or hacked.
              </p>
              <button class="close-btn" onclick="closeSecret()">
                Go Back
              </button>
            `;
          }, 1000);
        }
      }, 250);
    }

    function closeSecret() {
      document.getElementById('secretScreen').style.display = 'none';
    }

    // Keyboard support
    document.addEventListener('keydown', (e) => {
      const allowed = '0123456789+-*/.';

      if (allowed.includes(e.key)) {
        append(e.key);
      }

      if (e.key === 'Enter') {
        calculate();
      }

      if (e.key === 'Backspace') {
        display.value = display.value.slice(0, -1);
      }

      if (e.key.toLowerCase() === 'c') {
        clearDisplay();
      }
    });
  </script>

</body>
</html>
